{
  "name": "syncorswim",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform desktop application monorepo.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace @syncorswim/client",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint .",
    "smoke:electron": "node scripts/verify-electron-build.mjs",
    "start": "npm run start --workspace @syncorswim/client",
    "test": "npm run build --workspace @syncorswim/shared && vitest run --passWithNoTests",
    "typecheck": "tsc --build"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.9"
  }
}
